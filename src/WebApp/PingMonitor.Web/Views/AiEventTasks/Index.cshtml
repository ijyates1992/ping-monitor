@model PingMonitor.Web.ViewModels.AiEventTasks.AiEventTasksPageViewModel
@using PingMonitor.Web.Models
@{
    ViewData["Title"] = "Event-triggered AI tasks";
    var endpointStates = new[] { "Up", "Down", "Suppressed", "Degraded" };
    var agentStates = new[] { "Online", "Offline", "Stale" };
}
<!DOCTYPE html><html lang="en"><head>@await Html.PartialAsync("_ThemeHead")<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Event-triggered AI tasks</title><style>
:root{--bg:#f3f6f8;--card:#fff;--text:#102a43;--muted:#52606d;--border:#d9e2ec;--primary:#0f62fe;--danger:#b42318;--warning:#92400e;--ok:#137333}body{margin:0;font-family:Arial,sans-serif;background:var(--bg);color:var(--text)}.wrap{max-width:1120px;margin:0 auto;padding:1rem}.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1rem;margin-bottom:1rem}.section{border:1px solid var(--border);border-radius:14px;padding:1rem;margin:.75rem 0}.section h3{margin-top:0}.form-grid{display:grid;gap:.9rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr))}.field{display:flex;flex-direction:column;gap:.3rem}label,.label{font-weight:700}input,select,textarea{box-sizing:border-box;width:100%;min-height:44px;border:1px solid var(--border);border-radius:10px;padding:.6rem .7rem;background:var(--card);color:var(--text);font:inherit}select[multiple]{min-height:9rem}textarea{min-height:150px;resize:vertical}input[type=checkbox]{width:auto;min-height:auto}.check-row{display:flex;gap:.55rem;align-items:flex-start}.check-list{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.45rem}.scope-grid{display:grid;gap:.9rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}.rate-row{display:grid;grid-template-columns:minmax(90px,140px) minmax(150px,1fr);gap:.75rem}.button{display:inline-flex;align-items:center;justify-content:center;min-height:48px;border:0;border-radius:10px;background:var(--primary);color:#fff;font-weight:700;padding:.8rem 1rem;text-decoration:none}.button-danger{background:var(--danger)}.button-secondary{background:transparent;color:var(--primary);border:1px solid var(--border)}.muted{color:var(--muted)}.alert{border-radius:12px;padding:.85rem;margin-bottom:1rem}.error{background:#fff3f2;color:var(--danger)}.ok{background:#e7f6ec;color:var(--ok)}.warning{background:#fff7ed;color:var(--warning)}.field-error{color:var(--danger);font-size:.92rem}.task-list{display:grid;gap:.85rem}.task{border:1px solid var(--border);border-radius:14px;padding:1rem}.task-head{display:flex;justify-content:space-between;gap:.75rem;flex-wrap:wrap}.task-head h3{margin:0}.badge{display:inline-block;border:1px solid var(--border);border-radius:999px;padding:.2rem .55rem;font-size:.88rem}.meta{display:grid;gap:.45rem;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));margin:.75rem 0}.preview{max-height:4.8rem;overflow:hidden;border:1px solid var(--border);border-radius:10px;padding:.65rem;background:rgba(82,96,109,.08);white-space:pre-wrap}.actions{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}a{color:var(--primary);font-weight:700}@@media(max-width:560px){.wrap{padding:.75rem}.rate-row{grid-template-columns:1fr}.button{width:100%}}@@media(prefers-color-scheme:dark){:root{--bg:#0b1220;--card:#111827;--text:#e5e7eb;--muted:#9ca3af;--border:#374151;--primary:#60a5fa;--danger:#fca5a5;--warning:#fcd34d;--ok:#86efac}.error{background:#2a1111}.ok{background:#102a1a}.warning{background:#2a2111}}
</style></head><body>@await Html.PartialAsync("_AuthenticatedNav")<main class="wrap">
<section class="card"><h1>Event-triggered AI tasks</h1><p class="muted">Run a saved AI prompt after selected endpoint or agent state changes, then send the report to your linked Telegram account.</p><p><a asp-controller="AiScheduledTasks" asp-action="Index">Scheduled AI tasks</a> · <strong>Event-triggered AI tasks</strong></p></section>
@if(!Model.HasLinkedTelegramAccount){<div class="alert warning">Link your Telegram account before enabling event-triggered AI tasks. Arbitrary Telegram chat IDs, groups, and channels are not supported.</div>}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){<div class="alert error">@Model.ErrorMessage</div>}
@if(!string.IsNullOrWhiteSpace(Model.StatusMessage)){<div class="alert ok">@Model.StatusMessage</div>}
<section class="card"><h2>@(string.IsNullOrWhiteSpace(Model.Form.AiEventTriggeredTaskId)?"Create task":"Edit task")</h2><form asp-controller="AiEventTasks" asp-action="Save" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Form.AiEventTriggeredTaskId" />
<div class="section"><h3>Task details</h3><div class="form-grid"><div class="field"><label asp-for="Form.Name">Name</label><input asp-for="Form.Name" maxlength="128" /><div class="field-error"><span asp-validation-for="Form.Name"></span></div></div><div class="field"><span class="label">Status</span><label class="check-row"><input asp-for="Form.Enabled" type="checkbox" /> <span>Enabled</span></label><div class="field-error"><span asp-validation-for="Form.Enabled"></span></div></div></div><div class="field"><label asp-for="Form.Prompt">Prompt</label><textarea asp-for="Form.Prompt" maxlength="4000"></textarea><div class="field-error"><span asp-validation-for="Form.Prompt"></span></div></div></div>
<div class="section"><h3>Trigger event</h3><div class="field"><label asp-for="Form.TriggerType">Trigger type</label><select asp-for="Form.TriggerType" asp-items="Html.GetEnumSelectList<AiEventTriggerType>()"></select><div class="field-error"><span asp-validation-for="Form.TriggerType"></span></div></div><div class="form-grid"><div class="field"><span class="label">Endpoint target states</span><div class="check-list">@foreach(var s in endpointStates){<label class="check-row"><input type="checkbox" name="Form.EndpointTargetStates" value="@s" checked="@(Model.Form.EndpointTargetStates.Contains(s))" /> <span>@s</span></label>}</div></div><div class="field"><span class="label">Agent target states</span><div class="check-list">@foreach(var s in agentStates){<label class="check-row"><input type="checkbox" name="Form.AgentTargetStates" value="@s" checked="@(Model.Form.AgentTargetStates.Contains(s))" /> <span>@s</span></label>}</div></div></div></div>
<div class="section"><h3>Trigger scope</h3><div class="field"><label asp-for="Form.ScopeMode">Scope mode</label><select asp-for="Form.ScopeMode" asp-items="Html.GetEnumSelectList<AiEventTriggerScopeMode>()"></select><div class="field-error"><span asp-validation-for="Form.ScopeMode"></span></div></div><div class="scope-grid"><div class="field"><label>Selected endpoints</label><select name="Form.ScopeSelectionIds" multiple asp-items="Model.Endpoints"></select></div><div class="field"><label>Selected endpoint groups</label><select name="Form.ScopeSelectionIds" multiple asp-items="Model.Groups"></select></div><div class="field"><label>Selected agents</label><select name="Form.ScopeSelectionIds" multiple asp-items="Model.Agents"></select></div></div><p class="muted">Selections are used when the selected scope mode requires them.</p></div>
<div class="section"><h3>Rate limiting</h3><div class="field"><span class="label">No more than once every</span><div class="rate-row"><input asp-for="Form.RateLimitValue" min="1" step="1" /><select asp-for="Form.RateLimitUnit" asp-items="Html.GetEnumSelectList<AiEventTriggerRateLimitUnit>()"></select></div><div class="field-error"><span asp-validation-for="Form.RateLimitValue"></span><span asp-validation-for="Form.RateLimitUnit"></span></div></div></div>
<div class="section"><h3>Delivery</h3><p class="muted"><strong>Delivery:</strong> Telegram DM to my linked account. No arbitrary chat IDs, groups, or channels are supported.</p></div>
<div asp-validation-summary="ModelOnly" class="alert error"></div><button class="button" type="submit">Save event-triggered AI task</button></form></section>
<section class="card"><h2>My event-triggered AI tasks</h2>@if(Model.Tasks.Count==0){<p class="muted">No event-triggered AI tasks yet.</p>}else{<div class="task-list">@foreach(var task in Model.Tasks){<article class="task"><div class="task-head"><h3>@task.Name</h3><span class="badge">@(task.Enabled?"Enabled":"Disabled")</span></div><div class="meta"><div><strong>Trigger</strong><br />@task.TriggerType</div><div><strong>Scope</strong><br />@task.ScopeMode</div><div><strong>Rate limit</strong><br />Every @task.RateLimitValue @task.RateLimitUnit</div><div><strong>Last status</strong><br />@task.LastStatus</div><div><strong>Last trigger</strong><br />@(task.LastTriggeredAtUtc?.ToString("u") ?? "never")</div><div><strong>Last run</strong><br />@(task.LastRunAtUtc?.ToString("u") ?? "never")</div><div><strong>Rate-limited</strong><br />@task.RateLimitedCount</div></div>@if(!string.IsNullOrWhiteSpace(task.LastError)){<details><summary class="muted">Last error</summary><div class="preview">@task.LastError</div></details>}@if(!string.IsNullOrWhiteSpace(task.LastResponsePreview)){<details><summary class="muted">Last response preview</summary><div class="preview">@task.LastResponsePreview</div></details>}<div class="actions"><a class="button button-secondary" asp-controller="AiEventTasks" asp-action="Edit" asp-route-taskId="@task.AiEventTriggeredTaskId">Edit</a><form asp-controller="AiEventTasks" asp-action="Delete" method="post">@Html.AntiForgeryToken()<input type="hidden" name="taskId" value="@task.AiEventTriggeredTaskId" /><button class="button button-danger" type="submit">Delete</button></form></div></article>}</div>}</section>
</main></body></html>
