@model PingMonitor.Web.ViewModels.AiEventTasks.AiEventTasksPageViewModel
@using PingMonitor.Web.Models
@{
    ViewData["Title"] = "Event-triggered AI tasks";
    var endpointStates = new[] { "Up", "Down", "Suppressed", "Degraded" };
    var agentStates = new[] { "Online", "Offline", "Stale" };
}
<h1>Event-triggered AI tasks</h1>
<p class="text-muted">Run a saved AI prompt after selected endpoint or agent state changes, then send the report to your linked Telegram account.</p>
<p><a asp-controller="AiScheduledTasks" asp-action="Index">Scheduled AI tasks</a> · <strong>Event-triggered AI tasks</strong></p>
@if (!Model.HasLinkedTelegramAccount) { <div class="alert alert-warning">Link your Telegram account before enabling event-triggered AI tasks.</div> }
@if (!string.IsNullOrWhiteSpace(Model.StatusMessage)) { <div class="alert alert-success">@Model.StatusMessage</div> }
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }
<section class="card mb-4"><div class="card-body"><h2 class="h4">Task details</h2>
<form asp-action="Save" method="post">
<input type="hidden" asp-for="Form.AiEventTriggeredTaskId" />
<div class="mb-3"><label asp-for="Form.Name" class="form-label"></label><input asp-for="Form.Name" class="form-control" /></div>
<div class="mb-3"><label asp-for="Form.Prompt" class="form-label"></label><textarea asp-for="Form.Prompt" class="form-control" rows="5"></textarea></div>
<div class="form-check mb-3"><input asp-for="Form.Enabled" class="form-check-input" /><label asp-for="Form.Enabled" class="form-check-label"></label></div>
<h3 class="h5">Trigger event</h3>
<select asp-for="Form.TriggerType" class="form-select mb-3" asp-items="Html.GetEnumSelectList<AiEventTriggerType>()"></select>
<div class="mb-3"><strong>Endpoint target states</strong><div class="d-flex flex-wrap gap-3">@foreach (var s in endpointStates) { <label class="form-check"><input class="form-check-input" type="checkbox" name="Form.EndpointTargetStates" value="@s" checked="@(Model.Form.EndpointTargetStates.Contains(s))" /> @s</label> }</div></div>
<div class="mb-3"><strong>Agent target states</strong><div class="d-flex flex-wrap gap-3">@foreach (var s in agentStates) { <label class="form-check"><input class="form-check-input" type="checkbox" name="Form.AgentTargetStates" value="@s" checked="@(Model.Form.AgentTargetStates.Contains(s))" /> @s</label> }</div></div>
<h3 class="h5">Trigger scope</h3>
<select asp-for="Form.ScopeMode" class="form-select mb-3" asp-items="Html.GetEnumSelectList<AiEventTriggerScopeMode>()"></select>
<label class="form-label">Selected endpoints</label><select name="Form.ScopeSelectionIds" class="form-select mb-2" multiple asp-items="Model.Endpoints"></select>
<label class="form-label">Selected endpoint groups</label><select name="Form.ScopeSelectionIds" class="form-select mb-2" multiple asp-items="Model.Groups"></select>
<label class="form-label">Selected agents</label><select name="Form.ScopeSelectionIds" class="form-select mb-3" multiple asp-items="Model.Agents"></select>
<h3 class="h5">Rate limiting</h3>
<div class="row g-2 mb-3"><div class="col-6"><input asp-for="Form.RateLimitValue" class="form-control" /></div><div class="col-6"><select asp-for="Form.RateLimitUnit" class="form-select" asp-items="Html.GetEnumSelectList<AiEventTriggerRateLimitUnit>()"></select></div></div>
<p><strong>Delivery:</strong> Telegram DM to my linked account. No arbitrary chat IDs, groups, or channels are supported.</p>
<button class="btn btn-primary" type="submit">Save event-triggered AI task</button>
</form></div></section>
<section><h2 class="h4">My event-triggered AI tasks</h2>
@foreach (var task in Model.Tasks) { <article class="card mb-3"><div class="card-body"><h3 class="h5">@task.Name</h3><p>@task.TriggerType · @task.ScopeMode · no more than once every @task.RateLimitValue @task.RateLimitUnit</p><p>Status: @task.LastStatus · Last trigger: @(task.LastTriggeredAtUtc?.ToString("u") ?? "never") · Last run: @(task.LastRunAtUtc?.ToString("u") ?? "never") · Rate-limited: @task.RateLimitedCount</p>@if(!string.IsNullOrWhiteSpace(task.LastError)){<details><summary>Last error</summary><pre>@task.LastError</pre></details>}@if(!string.IsNullOrWhiteSpace(task.LastResponsePreview)){<details><summary>Last response preview</summary><pre>@task.LastResponsePreview</pre></details>}<a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-taskId="@task.AiEventTriggeredTaskId">Edit</a> <form asp-action="Delete" method="post" class="d-inline"><input type="hidden" name="taskId" value="@task.AiEventTriggeredTaskId" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></article> }
@if (Model.Tasks.Count == 0) { <p>No event-triggered AI tasks yet.</p> }
</section>
