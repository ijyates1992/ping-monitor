@model PingMonitor.Web.ViewModels.AiScheduledTasks.AiScheduledTasksPageViewModel
@using PingMonitor.Web.Models
@{
    ViewData["Title"] = "Scheduled AI tasks";
}
<!DOCTYPE html><html lang="en"><head>@await Html.PartialAsync("_ThemeHead")<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Scheduled AI tasks</title><style>
:root{--bg:#f3f6f8;--card:#fff;--text:#102a43;--muted:#52606d;--border:#d9e2ec;--primary:#0f62fe;--danger:#b42318;--ok:#137333}body{margin:0;font-family:Arial,sans-serif;background:var(--bg);color:var(--text)}.wrap{max-width:1120px;margin:0 auto;padding:1rem}.card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1rem;margin-bottom:1rem}.section{border:1px solid var(--border);border-radius:14px;padding:1rem;margin:.75rem 0}.section h3{margin-top:0}.form-grid{display:grid;gap:.9rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr))}.field{display:flex;flex-direction:column;gap:.3rem}label,.label{font-weight:700}input,select,textarea{box-sizing:border-box;width:100%;min-height:44px;border:1px solid var(--border);border-radius:10px;padding:.6rem .7rem;background:var(--card);color:var(--text);font:inherit}input[type=checkbox],input[type=radio]{width:auto;min-height:auto}.check-row,.radio-row{display:flex;gap:.55rem;align-items:flex-start}.radio-stack{display:grid;gap:.6rem}.repeat-row{display:grid;grid-template-columns:minmax(90px,140px) minmax(150px,1fr);gap:.75rem}textarea{min-height:150px;resize:vertical}.button{min-height:48px;border:0;border-radius:10px;background:var(--primary);color:#fff;font-weight:700;padding:.8rem 1rem}.button-danger{background:var(--danger)}.muted{color:var(--muted)}.alert{border-radius:12px;padding:.85rem;margin-bottom:1rem}.error{background:#fff3f2;color:var(--danger)}.ok{background:#e7f6ec;color:var(--ok)}.field-error{color:var(--danger);font-size:.92rem}.task-list{display:grid;gap:.85rem}.task{border:1px solid var(--border);border-radius:14px;padding:1rem}.task-head{display:flex;justify-content:space-between;gap:.75rem;flex-wrap:wrap}.badge{display:inline-block;border:1px solid var(--border);border-radius:999px;padding:.2rem .55rem;font-size:.88rem}.meta{display:grid;gap:.45rem;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));margin:.75rem 0}.preview{max-height:4.8rem;overflow:hidden;border:1px solid var(--border);border-radius:10px;padding:.65rem;background:rgba(82,96,109,.08);white-space:pre-wrap}.actions{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}a{color:var(--primary);font-weight:700}@@media(max-width:560px){.wrap{padding:.75rem}.repeat-row{grid-template-columns:1fr}.button{width:100%}}@@media(prefers-color-scheme:dark){:root{--bg:#0b1220;--card:#111827;--text:#e5e7eb;--muted:#9ca3af;--border:#374151;--primary:#60a5fa;--danger:#fca5a5;--ok:#86efac}.error{background:#2a1111}.ok{background:#102a1a}}
</style></head><body>@await Html.PartialAsync("_AuthenticatedNav")<main class="wrap">
<section class="card"><h1>Scheduled AI tasks</h1><p class="muted">Scheduled AI tasks run a saved prompt at the selected time and deliver the AI response to your linked Telegram account. Tasks are created and managed only from this page; AI chat cannot create or change schedules.</p><p><a asp-controller="AiAssistant" asp-action="Index">Back to AI Assistant</a></p></section>
@if(!Model.HasLinkedTelegramAccount){<div class="alert error">Link your Telegram account before enabling scheduled AI tasks. Arbitrary Telegram chat IDs, groups, and channels are not supported.</div>}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){<div class="alert error">@Model.ErrorMessage</div>}
@if(!string.IsNullOrWhiteSpace(Model.StatusMessage)){<div class="alert ok">@Model.StatusMessage</div>}
<section class="card"><h2>@(string.IsNullOrWhiteSpace(Model.Form.AiScheduledTaskId)?"Create task":"Edit task")</h2><form asp-controller="AiScheduledTasks" asp-action="Save" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Form.AiScheduledTaskId" />
<div class="section"><h3>Task details</h3><div class="form-grid"><div class="field"><label asp-for="Form.Name">Name</label><input asp-for="Form.Name" maxlength="128" /><div class="field-error"><span asp-validation-for="Form.Name"></span></div></div><div class="field"><span class="label">Status</span><label class="check-row"><input asp-for="Form.Enabled" type="checkbox" /> <span>Enabled</span></label><div class="field-error"><span asp-validation-for="Form.Enabled"></span></div></div></div><div class="field"><label asp-for="Form.Prompt">Prompt</label><textarea asp-for="Form.Prompt" maxlength="4000"></textarea><div class="field-error"><span asp-validation-for="Form.Prompt"></span></div></div></div>
<div class="section"><h3>Schedule</h3><div class="form-grid"><div class="field"><label asp-for="Form.FirstRunDate">First run date</label><input asp-for="Form.FirstRunDate" type="date" /><div class="field-error"><span asp-validation-for="Form.FirstRunDate"></span></div></div><div class="field"><label asp-for="Form.FirstRunTime">First run time</label><input asp-for="Form.FirstRunTime" type="time" step="60" /><div class="field-error"><span asp-validation-for="Form.FirstRunTime"></span></div></div><div class="field"><label asp-for="Form.TimeZoneId">Time zone</label><select asp-for="Form.TimeZoneId">@foreach(var option in Model.TimeZoneOptions){<option value="@option.Value">@option.Label</option>}</select><div class="field-error"><span asp-validation-for="Form.TimeZoneId"></span></div></div></div><p class="muted">The first run date and time are interpreted in the selected time zone. Runs are stored internally in UTC.</p><label class="check-row" style="margin-top:.75rem"><input asp-for="Form.RepeatEnabled" type="checkbox" /> <span>Repeat this task</span></label><div class="field" style="margin-top:.75rem"><span class="label">Repeat every</span><div class="repeat-row"><input asp-for="Form.RepeatEvery" min="1" step="1" /><select asp-for="Form.RepeatUnit" asp-items="Html.GetEnumSelectList<AiScheduledTaskRepeatUnit>()"></select></div><div class="field-error"><span asp-validation-for="Form.RepeatEvery"></span><span asp-validation-for="Form.RepeatUnit"></span></div><p class="muted">Minimum interval is 1 hour. Minutes, seconds, cron expressions, free-text parsing, and AI-generated schedules are not supported.</p></div><div class="field"><span class="label">Missed run behaviour</span><div class="radio-stack"><label class="radio-row"><input asp-for="Form.MissedRunPolicy" type="radio" value="Skip" /> <span>Skip missed runs and resume at the next future time.</span></label><label class="radio-row"><input asp-for="Form.MissedRunPolicy" type="radio" value="RetryOnce" /> <span>Run once as soon as possible, then resume the schedule.</span></label></div><div class="field-error"><span asp-validation-for="Form.MissedRunPolicy"></span></div></div></div>
<div class="section"><h3>Delivery</h3><div class="field"><label asp-for="Form.DeliveryTarget">Delivery</label><select asp-for="Form.DeliveryTarget" asp-items="Html.GetEnumSelectList<AiScheduledTaskDeliveryTarget>()"></select><p class="muted">Delivery is limited to Telegram for your linked account.</p><div class="field-error"><span asp-validation-for="Form.DeliveryTarget"></span></div></div></div>
<div asp-validation-summary="ModelOnly" class="alert error"></div><button class="button" type="submit">Save scheduled AI task</button></form></section>
<section class="card"><h2>Your scheduled AI tasks</h2>@if(Model.Tasks.Count==0){<p class="muted">No scheduled AI tasks yet.</p>}else{<div class="task-list">@foreach(var t in Model.Tasks){<article class="task"><div class="task-head"><h3>@t.Name</h3><span class="badge">@(t.Enabled?"Enabled":"Disabled")</span></div><div class="meta"><div><strong>Next run</strong><br />@(t.NextRunAtUtc?.ToString("u") ?? "none")</div><div><strong>Repeat</strong><br />@t.RepeatSummary</div><div><strong>Last status</strong><br />@t.LastStatus</div><div><strong>Last run</strong><br />@(t.LastRunAtUtc?.ToString("u") ?? "never")</div></div>@if(!string.IsNullOrWhiteSpace(t.LastError)){<div class="alert error">Last error: @t.LastError</div>}@if(!string.IsNullOrWhiteSpace(t.LastResponsePreview)){<details><summary class="muted">Last response preview</summary><div class="preview">@t.LastResponsePreview</div></details>}<div class="actions"><a asp-controller="AiScheduledTasks" asp-action="Edit" asp-route-taskId="@t.AiScheduledTaskId">Edit</a><form asp-controller="AiScheduledTasks" asp-action="Delete" method="post">@Html.AntiForgeryToken()<input type="hidden" name="taskId" value="@t.AiScheduledTaskId" /><button class="button button-danger" type="submit">Delete</button></form></div></article>}</div>}</section>
</main></body></html>
