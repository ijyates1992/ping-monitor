@model PingMonitor.Web.ViewModels.AiScheduledTasks.AiScheduledTasksPageViewModel
@using PingMonitor.Web.Models
@{
    ViewData["Title"] = "Scheduled AI tasks";
}
<!DOCTYPE html><html lang="en"><head>@await Html.PartialAsync("_ThemeHead")<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Scheduled AI tasks</title><style>
body{margin:0;font-family:Arial,sans-serif;background:#f3f6f8;color:#102a43}.wrap{max-width:1100px;margin:0 auto;padding:1rem}.card{background:#fff;border:1px solid #d9e2ec;border-radius:14px;padding:1rem;margin-bottom:1rem}.grid{display:grid;gap:.75rem}.form-grid{display:grid;gap:.75rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}input,select,textarea{width:100%;min-height:44px;border:1px solid #d9e2ec;border-radius:10px;padding:.6rem}textarea{min-height:140px}.button{min-height:48px;border:0;border-radius:10px;background:#0f62fe;color:#fff;font-weight:700;padding:.8rem 1rem}.button-danger{background:#b42318}.muted{color:#52606d}.alert{border-radius:12px;padding:.85rem}.error{background:#fff3f2;color:#b42318}.ok{background:#e7f6ec;color:#137333}.task{border-top:1px solid #d9e2ec;padding-top:.75rem}.actions{display:flex;gap:.5rem;flex-wrap:wrap}a{color:#0f62fe;font-weight:700}</style></head><body>@await Html.PartialAsync("_AuthenticatedNav")<main class="wrap">
<section class="card"><h1>Scheduled AI tasks</h1><p class="muted">Scheduled AI tasks run a saved prompt at the selected time and deliver the AI response to your linked Telegram account. Tasks are created and managed only from this page; AI chat cannot create or change schedules.</p><p><a asp-controller="AiAssistant" asp-action="Index">Back to AI Assistant</a></p></section>
@if(!Model.HasLinkedTelegramAccount){<div class="alert error">Link your Telegram account before enabling scheduled AI tasks. Arbitrary Telegram chat IDs, groups, and channels are not supported.</div>}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){<div class="alert error">@Model.ErrorMessage</div>}
@if(!string.IsNullOrWhiteSpace(Model.StatusMessage)){<div class="alert ok">@Model.StatusMessage</div>}
<section class="card"><h2>@(string.IsNullOrWhiteSpace(Model.Form.AiScheduledTaskId)?"Create task":"Edit task")</h2><form asp-controller="AiScheduledTasks" asp-action="Save" method="post" class="grid">@Html.AntiForgeryToken()<input type="hidden" asp-for="Form.AiScheduledTaskId" />
<div class="form-grid"><div><label asp-for="Form.Name"></label><input asp-for="Form.Name" maxlength="128" /></div><div><label asp-for="Form.ScheduleKind"></label><select asp-for="Form.ScheduleKind" asp-items="Html.GetEnumSelectList<AiScheduledTaskScheduleKind>()"></select></div><div><label asp-for="Form.TimeZoneId"></label><input asp-for="Form.TimeZoneId" placeholder="UTC" /></div><div><label asp-for="Form.DeliveryTarget"></label><select asp-for="Form.DeliveryTarget" asp-items="Html.GetEnumSelectList<AiScheduledTaskDeliveryTarget>()"></select></div></div>
<div><label asp-for="Form.Prompt"></label><textarea asp-for="Form.Prompt" maxlength="4000"></textarea></div>
<div class="form-grid"><label><input asp-for="Form.Enabled" type="checkbox" /> Enabled</label><div><label asp-for="Form.RunOnceAtUtc">Run once at (UTC)</label><input asp-for="Form.RunOnceAtUtc" /></div><div><label asp-for="Form.TimeOfDayLocal">Time of day</label><input asp-for="Form.TimeOfDayLocal" type="time" /></div><div><label asp-for="Form.DayOfWeek"></label><select asp-for="Form.DayOfWeek"><option value="">Select</option>@foreach(var d in Enum.GetValues<DayOfWeek>()){<option value="@d">@d</option>}</select></div><div><label asp-for="Form.DayOfMonth">Day of month (1-28)</label><input asp-for="Form.DayOfMonth" min="1" max="28" /></div></div>
<div asp-validation-summary="All" class="error"></div><button class="button" type="submit">Save scheduled AI task</button></form></section>
<section class="card"><h2>Your scheduled AI tasks</h2>@if(Model.Tasks.Count==0){<p class="muted">No scheduled AI tasks yet.</p>}else{@foreach(var t in Model.Tasks){<article class="task"><h3>@t.Name</h3><p><strong>@t.ScheduleKind</strong> · @(t.Enabled?"Enabled":"Disabled") · Next: @(t.NextRunAtUtc?.ToString("u") ?? "none") · Last: @t.LastStatus</p><p class="muted">Last run: @(t.LastRunAtUtc?.ToString("u") ?? "never")</p>@if(!string.IsNullOrWhiteSpace(t.LastError)){<p class="error">Last error: @t.LastError</p>}@if(!string.IsNullOrWhiteSpace(t.LastResponsePreview)){<p class="muted">Last response preview: @t.LastResponsePreview</p>}<div class="actions"><a asp-controller="AiScheduledTasks" asp-action="Edit" asp-route-taskId="@t.AiScheduledTaskId">Edit</a><form asp-controller="AiScheduledTasks" asp-action="Delete" method="post">@Html.AntiForgeryToken()<input type="hidden" name="taskId" value="@t.AiScheduledTaskId" /><button class="button button-danger" type="submit">Delete</button></form></div></article>}}</section>
</main></body></html>
